#include <WiFi.h>
#include <PubSubClient.h>
#include <FastLED.h>

#define LED_PIN 5
#define NUM_LEDS 90
#define DEFAULT_BRIGHTNESS 20
#define LED_TYPE WS2812B
#define COLOR_ORDER BRG

CRGB leds[NUM_LEDS];

const char* ssid = "XXXXX";
const char* password = "XXXXXXX";

const char* mqtt_server = "XXXXX";
const int mqtt_port = XXXXXX;

WiFiClient espClient;
PubSubClient client(espClient);

void setColor(CRGB color) {
  fill_solid(leds, NUM_LEDS, color);
  FastLED.show();
}
    
void setNightMode() {
  FastLED.setBrightness(20);
  fill_solid(leds, NUM_LEDS, CRGB(255, 55, 0));
  FastLED.show();
}

void setStudioMode() {
  FastLED.setBrightness(80);
  fill_solid(leds, NUM_LEDS, CRGB(180, 0, 255));
  FastLED.show();
}

void handleRgbCommand(String msg) {
  int r = 0;
  int g = 0;
  int b = 0;
  int br = DEFAULT_BRIGHTNESS;

  int firstComma = msg.indexOf(',');
  int secondComma = msg.indexOf(',', firstComma + 1);
  int thirdComma = msg.indexOf(',', secondComma + 1);
  int fourthComma = msg.indexOf(',', thirdComma + 1);

  if (firstComma > 0 && secondComma > firstComma && thirdComma > secondComma && fourthComma > thirdComma) {
    r = msg.substring(firstComma + 1, secondComma).toInt();
    g = msg.substring(secondComma + 1, thirdComma).toInt();
    b = msg.substring(thirdComma + 1, fourthComma).toInt();
    br = msg.substring(fourthComma + 1).toInt();

    r = constrain(r, 0, 255);
    g = constrain(g, 0, 255);
    b = constrain(b, 0, 255);
    br = constrain(br, 0, 255);

    FastLED.setBrightness(br);

    for (int i = 0; i < NUM_LEDS; i++) {
      leds[i] = CRGB(r, g, b);
    }

    FastLED.show();

    Serial.print("Ustawiono CALY PASEK RGB: ");
    Serial.print(r);
    Serial.print(",");
    Serial.print(g);
    Serial.print(",");
    Serial.print(b);
    Serial.print(" jasnosc: ");
    Serial.println(br);
  } else {
    Serial.println("Blad formatu RGB");
  }
}

void callback(char* topic, byte* payload, unsigned int length) {
  String msg = "";

  for (unsigned int i = 0; i < length; i++) {
    msg += (char)payload[i];
  }

  msg.trim();

  Serial.print("MQTT odebrano [");
  Serial.print(topic);
  Serial.print("]: ");
  Serial.println(msg);

  if (msg.startsWith("RGB,")) {
    handleRgbCommand(msg);
    return;
  }

  msg.toUpperCase();

  FastLED.setBrightness(DEFAULT_BRIGHTNESS);

  if (msg == "RED") {
    setColor(CRGB::Red);
  } else if (msg == "GREEN") {
    setColor(CRGB::Green);
  } else if (msg == "BLUE") {
    setColor(CRGB::Blue);
  } else if (msg == "WHITE") {
    setColor(CRGB::White);
  } else if (msg == "OFF") {
    setColor(CRGB::Black);
  } else if (msg == "NIGHT") {
    setNightMode();
  } else if (msg == "STUDIO") {
    setStudioMode();
  } else {
    Serial.println("Nieznana komenda");
  }
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Laczenie z MQTT... ");

    String clientId = "ESP32_LED_";
    clientId += String((uint32_t)ESP.getEfuseMac(), HEX);

    if (client.connect(clientId.c_str())) {
      Serial.println("OK");

      client.subscribe("home/led/set");
      client.publish("home/led/status", "ESP32 ONLINE");

      setColor(CRGB::Blue);
      delay(300);
      setColor(CRGB::Black);
    } else {
      Serial.print("blad, rc=");
      Serial.print(client.state());
      Serial.println(" ponawiam za 5s");
      delay(5000);
    }
  }
}

void setup() {
  delay(1000);
  Serial.begin(115200);

  Serial.println();
  Serial.println("Start ESP8266 LED MQTT");

  FastLED.addLeds<LED_TYPE, LED_PIN, COLOR_ORDER>(leds, NUM_LEDS);
  FastLED.setBrightness(DEFAULT_BRIGHTNESS);

  setColor(CRGB::Red);
  delay(300);
  setColor(CRGB::Black);

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  Serial.print("Laczenie z WiFi");

  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 40) {
    delay(500);
    Serial.print(".");
    tries++;
  }

  Serial.println();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("WiFi OK, IP ESP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("WiFi NIE POLACZONO");
    Serial.print("Status: ");
    Serial.println(WiFi.status());
  }

  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(callback);
}

void loop() {
  if (WiFi.status() == WL_CONNECTED) {
    if (!client.connected()) {
      reconnect();
    }

    client.loop();
  }
}
